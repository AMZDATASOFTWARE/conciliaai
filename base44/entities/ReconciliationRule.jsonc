{
  "name": "ReconciliationRule",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "ID do Tenant"
    },
    "keyword": {
      "type": "string",
      "description": "Palavra-chave a buscar na descri\u00e7\u00e3o, ex: WILSON DE CASSIO"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Varia\u00e7\u00f5es/apelidos que tamb\u00e9m devem casar (ex.: keyword=\"DAVID LEONARDO BRAGA PANTOJA\", aliases=[\"LEO\",\"L\u00c9O\"])"
    },
    "map_to": {
      "type": "string",
      "description": "Nome mapeado, ex: Jhennifer"
    },
    "category": {
      "type": "string",
      "description": "Categoria cont\u00e1bil, ex: Di\u00e1rias"
    },
    "cost_center_id": {
      "type": "string",
      "description": "ID do CostCenter"
    },
    "is_pf": {
      "type": "boolean",
      "default": false,
      "description": "Pessoa f\u00edsica"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "match_count": {
      "type": "number",
      "default": 0,
      "description": "Contador de uso da regra"
    },
    "created_by": {
      "type": "string",
      "description": "Origem da regra: 'human', 'system_feedback_loop', ou 'super_agente'"
    },
    "approval_status": {
      "type": "string",
      "enum": [
        "pending_review",
        "approved",
        "rejected"
      ],
      "default": "pending_review",
      "description": "Regras aprendidas pela IA nascem pending_review; s\u00f3 valem depois de aprovadas por humano"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Dados de auditoria: descri\u00e7\u00e3o original, categoria antiga/nova, record de origem, flag_risco (ex.: pagamento a terceiro em nome de outra pessoa)"
    }
  },
  "required": [
    "tenant_id",
    "keyword"
  ]
}